{
  "productName": "remote-desktop",
  "version": "0.1.0",
  "identifier": "com.remote-desktop.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Remote Desktop",
        "width": 900,
        "height": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ws: wss: http: https:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
